{
  "name": "jobs-telescope-ui",
  "version": "0.0.1",
  "description": "Jobs Telescope UI - TUI for searching jobs",
  "type": "module",
  "bin": {
    "jobs-telescope": "./src/index.tsx"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "start": "tsx src/index.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
